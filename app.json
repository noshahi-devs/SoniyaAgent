{
  "expo": {
    "name": "Soniya Agent",
    "slug": "SoniyaAgent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soniyaagent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.soniyaagent",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Soniya ko aapki baat sunne ke liye Mic ki zaroorat hai.",
        "NSSpeechRecognitionUsageDescription": "Soniya aapki awaz samajhne ke liye recognition use karegi."
      }
    },
    "android": {
      "package": "com.yourname.soniyaagent",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#050111"
      },
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "favicon": "./assets/images/android-icon-foreground.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#000000"
        }
      ],
      "expo-speech-recognition",
      "expo-font"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "4fecd7ce-e39d-4c9c-96c0-be4e81368f23"
      }
    },
    "updates": {}
  }
}
