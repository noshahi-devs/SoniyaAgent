{
  "expo": {
    "name": "SoniyaAgent",
    "slug": "SoniyaAgent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soniyaagent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.soniyaagent",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Soniya ko aapki baat sunne ke liye Mic ki zaroorat hai.",
        "NSSpeechRecognitionUsageDescription": "Soniya aapki awaz samajhne ke liye recognition use karegi."
      }
    },
    "android": {
      "package": "com.yourname.soniyaagent",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#E6F4FE"
      },
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-speech-recognition"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8ff6606c-bea4-486b-99cf-d1267712241d"
      }
    }
  }
}
