{
  "expo": {
    "name": "Soniya Agent",
    "slug": "SoniyaAgent",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "orientation": "portrait",
    "icon": "./assets/images/android-icon-foreground.png",
    "splash": {
      "image": "./assets/images/android-icon-foreground.png",
      "resizeMode": "cover",
      "backgroundColor": "#693F4A"
    },
    "scheme": "soniyaagent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.soniyaagent",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Soniya ko aapki baat sunne ke liye Mic ki zaroorat hai.",
        "NSSpeechRecognitionUsageDescription": "Soniya aapki awaz samajhne ke liye recognition use karegi."
      }
    },
    "android": {
      "package": "com.yourname.soniyaagent",
      "icon": "./assets/images/android-icon-foreground.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#050111"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/images/android-icon-foreground.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/android-icon-foreground.png",
          "resizeMode": "cover",
          "backgroundColor": "#090979",
          "imageWidth": 1080
        }
      ],
      "expo-speech-recognition",
      "expo-font"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8ff6606c-bea4-486b-99cf-d1267712241d"
      }
    },
    "updates": {
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/8ff6606c-bea4-486b-99cf-d1267712241d"
    },
    "owner": "nabeel-khalil"
  }
}
