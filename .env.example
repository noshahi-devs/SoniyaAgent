# Public env vars used in JS bundle
EXPO_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here
EXPO_PUBLIC_OPENROUTER_MODEL=openrouter/auto
EXPO_PUBLIC_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EXPO_PUBLIC_OPENROUTER_APP_NAME=SoniyaAgent
# Optional but recommended by OpenRouter for better attribution
EXPO_PUBLIC_OPENROUTER_HTTP_REFERER=https://example.com
