# Public env vars used in JS bundle
# Recommended: secure proxy URL (keys stay on backend)
EXPO_PUBLIC_SECURE_PROXY_URL=http://localhost:8787

# Legacy direct mode (less secure, keys exposed in client bundle)
# EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key_here
# EXPO_PUBLIC_GROQ_MODEL=llama-3.1-8b-instant
# EXPO_PUBLIC_GROQ_BASE_URL=https://api.groq.com/openai/v1
# EXPO_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here
# EXPO_PUBLIC_OPENROUTER_MODEL=google/gemini-3-flash-preview
# EXPO_PUBLIC_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# EXPO_PUBLIC_OPENROUTER_APP_NAME=SoniyaAgent
# EXPO_PUBLIC_OPENROUTER_HTTP_REFERER=https://example.com
